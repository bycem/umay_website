---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="İletişim — Umay Okçuluk"
  description="Umay Okçuluk Kulübü adres, e-posta ve Instagram iletişim bilgileri."
>
  <section class="container">
    <p class="overline fade-up">İLETİŞİM</p>
    <h1 class="fade-up">İletişim</h1>

    <div class="cards fade-up">
      <div class="card">
        <span class="label">Adres</span>
        <p>Hürriyet Mahallesi, Alan Sokak, No:29/B, Lüleburgaz / Kırklareli</p>
      </div>

      <div class="card">
        <span class="label">E-posta</span>
        <p><a href="mailto:umayokculuk@gmail.com">umayokculuk@gmail.com</a></p>
      </div>

      <div class="card">
        <span class="label">Instagram</span>
        <p>
          <a
            href="https://www.instagram.com/umay_okculuk/"
            target="_blank"
            rel="noopener noreferrer"
          >
            @umay_okculuk
          </a>
        </p>
      </div>
    </div>

    <div class="map fade-up">
      <iframe
        src="https://www.google.com/maps?q=H%C3%BCrriyet+Mahallesi+Alan+Sokak+29%2FB+L%C3%BCleburgaz&output=embed"
        loading="lazy"
        title="Umay Okçuluk konum"
        width="100%"
        height="400"
        style="border:0;"
      ></iframe>
    </div>
  </section>
</Layout>

<style>
  h1 {
    margin-top: 12px;
    margin-bottom: 32px;
    font-size: 2.25rem;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 24px;
    border-radius: 16px;
    background: var(--surface);
    box-shadow: var(--shadow-sm);
  }

  .label {
    color: var(--accent);
    text-transform: uppercase;
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    font-weight: 600;
  }

  .card p {
    color: var(--ink-soft);
    font-size: 1rem;
    line-height: 1.6;
  }

  .card a {
    color: var(--ink);
    font-weight: 600;
    text-decoration: none;
  }

  .card a:hover {
    color: var(--accent);
    text-decoration: underline;
  }

  .map {
    margin-top: 40px;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }

  .map iframe {
    display: block;
    border-radius: 16px;
  }

  @media (max-width: 768px) {
    h1 {
      font-size: 1.75rem;
    }

    .cards {
      grid-template-columns: 1fr;
    }
  }
</style>
