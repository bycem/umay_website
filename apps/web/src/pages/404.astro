---
import Layout from '../layouts/Layout.astro';

Astro.response.status = 404;
---

<Layout title="Sayfa bulunamadı — Umay Okçuluk">
  <section class="container error fade-up">
    <p class="code">404</p>
    <p class="message">Aradığınız sayfa bulunamadı.</p>
    <a href="/" class="home-link">Anasayfaya dön</a>
  </section>
</Layout>

<style>
  .error {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
    padding-block: 96px;
  }

  .code {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: clamp(4rem, 12vw, 8rem);
    color: var(--accent);
    line-height: 1;
  }

  .message {
    color: var(--ink-soft);
    font-size: 1.1rem;
  }

  .home-link {
    margin-top: 8px;
    color: var(--accent);
    font-weight: 600;
    text-decoration: none;
  }

  .home-link:hover {
    text-decoration: underline;
  }
</style>
