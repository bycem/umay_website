# Neon (Netlify DB) bağlantı adresi. Netlify'da "Netlify DB" eklendiğinde otomatik enjekte edilir.
# Yerelde `netlify dev` çalıştırmadan önce veya migration script'i için elle tanımlayın.
NETLIFY_DATABASE_URL=

# Admin kullanıcıları artık DB'deki admin_users tablosunda tutulur.
# Kullanıcı eklemek/şifre güncellemek için: npm run db:create-admin <username> <password>

# JWT oturum imzalama anahtarı. `openssl rand -base64 32` ile üretin.
SESSION_SECRET=
