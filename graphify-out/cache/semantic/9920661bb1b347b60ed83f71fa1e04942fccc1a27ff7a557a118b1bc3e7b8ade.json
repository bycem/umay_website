{"nodes": [{"id": "docs_superpowers_specs_2026_07_04_umay_web_rewrite_design", "label": "Umay Web Rewrite Design Document", "file_type": "document", "source_file": "docs/superpowers/specs/2026-07-04-umay-web-rewrite-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_superpowers_specs_2026_07_04_umay_web_rewrite_design_ok_murekkep_visual_identity", "label": "Ok & M\u00fcrekkep Visual Identity", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-04-umay-web-rewrite-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Old navy+gold identity abandoned for a fresh warm-neutral background with vermilion (target-red) accent, large editorial typography and minimalism; overline labels replace the old gold underline."}, {"id": "docs_superpowers_specs_2026_07_04_umay_web_rewrite_design_design_token_palette", "label": "Design Token Palette", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-07-04-umay-web-rewrite-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_superpowers_specs_2026_07_04_umay_web_rewrite_design_two_app_isolation", "label": "Two-App Isolation Architecture", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-04-umay-web-rewrite-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Public (Astro SSR, read-only, no public API) and admin (Vite React SPA + Netlify Functions, schema owner) deploy as two separate Netlify sites sharing only the Neon DB, so a breach of the public site cannot directly reach the admin panel."}, {"id": "docs_superpowers_specs_2026_07_04_umay_web_rewrite_design_admin_auth_security", "label": "Admin Authentication & Security Model", "file_type": "rationale", "source_file": "docs/superpowers/specs/2026-07-04-umay-web-rewrite-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Single shared bcrypt-hashed password (no account system, Google OAuth removed) with HS256 JWT in an httpOnly+Secure+SameSite=Strict cookie (never localStorage, to block XSS token theft); bcryptjs chosen over bcrypt to avoid native bindings on Netlify Functions; Origin header check guards mutations."}, {"id": "docs_superpowers_specs_2026_07_04_umay_web_rewrite_design_database_schema", "label": "Database Schema (sliders, announcements, login_attempts)", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-07-04-umay-web-rewrite-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "admin_users and settings tables intentionally omitted because the tournament link was severed and a single-password model is used; public visibility rule is is_active = TRUE AND publish_date <= NOW()."}, {"id": "docs_superpowers_specs_2026_07_04_umay_web_rewrite_design_admin_api", "label": "Admin API Path-Based Router Endpoints", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-07-04-umay-web-rewrite-design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Single Netlify Function with a path-based router; /api/sliders/reorder must be registered before /api/sliders/:id so the static route wins."}], "edges": [{"source": "docs_superpowers_specs_2026_07_04_umay_web_rewrite_design_ok_murekkep_visual_identity", "target": "docs_superpowers_specs_2026_07_04_umay_web_rewrite_design_design_token_palette", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-07-04-umay-web-rewrite-design.md", "source_location": null, "weight": 1.0}, {"source": "docs_superpowers_specs_20